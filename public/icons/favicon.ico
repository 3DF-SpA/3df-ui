<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
  <!-- Fondo verde oscuro bosque -->
  <rect width="32" height="32" rx="5" fill="#1e3812"/>

  <!-- CORNAMENTA IZQUIERDA -->
  <!-- Viga principal: base del cráneo → arriba-izquierda -->
  <line x1="13.5" y1="18" x2="7" y2="4"  stroke="#d4a030" stroke-width="3"   stroke-linecap="round"/>
  <!-- Tina cejar (brow tine) -->
  <line x1="10"   y1="11" x2="5.5" y2="7" stroke="#d4a030" stroke-width="2.2" stroke-linecap="round"/>
  <!-- Tina superior -->
  <line x1="7.5"  y1="5.5" x2="4"  y2="3" stroke="#d4a030" stroke-width="2"   stroke-linecap="round"/>

  <!-- CORNAMENTA DERECHA (espejo) -->
  <line x1="18.5" y1="18" x2="25"  y2="4"  stroke="#d4a030" stroke-width="3"   stroke-linecap="round"/>
  <line x1="22"   y1="11" x2="26.5" y2="7" stroke="#d4a030" stroke-width="2.2" stroke-linecap="round"/>
  <line x1="24.5" y1="5.5" x2="28"  y2="3" stroke="#d4a030" stroke-width="2"   stroke-linecap="round"/>

  <!-- CABEZA - óvalo bold dorado -->
  <ellipse cx="16" cy="23" rx="5.5" ry="6.5" fill="#d4a030"/>
  <!-- Hocico - tono más oscuro -->
  <ellipse cx="16" cy="26.5" rx="3.2" ry="2.2" fill="#a87820"/>
  <!-- Ojos - puntos oscuros -->
  <circle cx="13.5" cy="21.5" r="0.9" fill="#1e3812"/>
  <circle cx="18.5" cy="21.5" r="0.9" fill="#1e3812"/>
</svg>
