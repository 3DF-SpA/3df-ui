{
  "name": "@3df-spa/ui",
  "version": "1.0.5",
  "description": "Vue 3 component library — TypeScript strict, Tailwind CSS v4, accessible, zero-runtime",
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "design-system",
    "tailwind",
    "typescript",
    "accessible"
  ],
  "homepage": "https://github.com/3DF-SpA/3df-ui#readme",
  "bugs": {
    "url": "https://github.com/3DF-SpA/3df-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/3DF-SpA/3df-ui.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "pnpm run build",
    "dev": "vite build --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./src/styles/theme.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "date-fns": "^3.0.0 || ^4.0.0",
    "embla-carousel": "^8.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel": "^8.6.0",
    "vite": "^7.3.1",
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.27"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
